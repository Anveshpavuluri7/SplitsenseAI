FROM python:3.11-slim

WORKDIR /app

# Minimal deps — only what the Streamlit UI needs
RUN pip install --no-cache-dir \
    streamlit==1.38.0 \
    plotly==5.24.0 \
    requests==2.32.3

COPY dashboard/ ./dashboard/

EXPOSE 8501

CMD ["streamlit", "run", "dashboard/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
